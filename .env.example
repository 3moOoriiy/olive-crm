# Server
PORT=3000

# JWT Secret - CHANGE THIS IN PRODUCTION!
JWT_SECRET=your-super-secret-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=5

# ═══════════════ J&T Express Egypt ═══════════════
# Get authToken from J&T merchant portal (Network tab → any request)
JT_AUTH_TOKEN=
JT_BASE_URL=https://vipgw.jtjms-eg.com
# Default sender info — used when shipping a CRM order
JT_SENDER_NAME=
JT_SENDER_PHONE=
JT_SENDER_PROVINCE=
JT_SENDER_CITY=
JT_SENDER_AREA=
JT_SENDER_STREET=

# ═══════════════ Public Integration Webhook ═══════════════
# Set a strong random secret; external websites pass it via
# X-API-Key header (or apiKey body field) to POST new orders.
INTEGRATION_API_KEY=

# ═══════════════ Shopify Webhook ═══════════════
# Set this to the secret shown in Shopify Dashboard → Notifications.
# When set, the server verifies the X-Shopify-Hmac-Sha256 header for every
# webhook request. Leave blank during local testing only.
SHOPIFY_WEBHOOK_SECRET=

# ═══════════════ Shopify Admin (auto-register webhook) ═══════════════
# Used to call Shopify Admin API and register the webhook automatically
# without logging into Shopify Dashboard.
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2026-04
SHOPIFY_WEBHOOK_TARGET=https://olive-crm.onrender.com/api/shopify/webhook/orders
